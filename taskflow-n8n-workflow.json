            {
              "value1": "={{$json.body.event}}",
              "value2": "sprint.started"
            }
          ]
        }
      },
      "id": "if-sprint-started",
      "name": "If Sprint Started",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
